{{#if formRelated}}
import { LitElement, html, unsafeCSS } from "lit";
import { NysFormControlElement } from "@nysds/internals";
{{else}}
import { html, unsafeCSS } from "lit";
import { NysElement } from "@nysds/internals";
{{/if}}
import { property } from "lit/decorators.js";
// @ts-ignore: SCSS module imported via bundler as inline
import styles from "./nys-{{componentName}}.scss?inline";

/**
 * `<nys-{{componentName}}>` is ...
 *
 * Extends {{#if formRelated}}`NysFormControlElement`{{else}}`NysElement`{{/if}} from `@nysds/internals`, which provides
 * {{#if formRelated}}form association (ElementInternals), validity helpers, and {{/if}}automatic
 * id generation. See `nys-{{#if formRelated}}textinput{{else}}alert{{/if}}` for a reference implementation.
 */

export class Nys{{capitalize componentName}} extends {{#if formRelated}}NysFormControlElement{{else}}NysElement{{/if}} {
  static styles = unsafeCSS(styles);
  {{#if formRelated}}
  static shadowRootOptions = {
    ...LitElement.shadowRootOptions,
    delegatesFocus: true,
  };
  {{/if}}

  /** Unique identifier. Auto-generated by the shared base if not provided. */
  @property({ type: String, reflect: true }) id = "";
  @property({ type: String, reflect: true }) name = "";
  {{#if formRelated}}
  /** Visible label text. Required for accessibility. */
  @property({ type: String }) label = "";
  @property({ type: String }) value = "";
  @property({ type: Boolean, reflect: true }) disabled = false;
  @property({ type: Boolean, reflect: true }) required = false;
  @property({ type: Boolean, reflect: true }) optional = false;
  @property({ type: Boolean, reflect: true }) showError = false;
  @property({ type: String }) errorMessage = "";
  /** Accessible label used only when no visible `label` is provided. */
  @property({ type: String }) ariaLabel = "";
  @property({ type: String, reflect: true }) form: string | null = null;
  {{/if}}

  {{#if formRelated}}
  /**
   * Lifecycle methods
   * --------------------------------------------------------------------------
   * Form association, ElementInternals, and id generation are provided by
   * NysFormControlElement (@nysds/internals).
   */
  connectedCallback() {
    super.connectedCallback(); // assigns an auto id when none is provided
    this.addEventListener("invalid", this._handleInvalid);
  }

  firstUpdated() {
    // Ensure the element always participates in the form.
    this._setValue();
  }

  updated(changedProperties: Map<string | number | symbol, unknown>) {
    if (changedProperties.has("value")) {
      this._setValue();
    }
  }

  /**
   * Form Integration
   * --------------------------------------------------------------------------
   * Shared helpers from NysFormControlElement (see nys-textinput for full usage):
   *   this.setFormValue(value)                       — push value to the owning form
   *   this.setValidityFromState(flags, msg, anchor)  — set validity + aria-invalid
   *   this.clearValidity()                           — clear validity + aria-invalid
   *   this.checkValidity() / this.reportValidity()
   *
   * Associate the native control's accessible name with the visible <nys-label>
   * via `aria-labelledby` (not a synthetic aria-label), and the error message via
   * `aria-errormessage`. Self-register <nys-label>/<nys-errormessage> by importing
   * "@nysds/nys-label" / "@nysds/nys-errormessage" if this component renders them.
   */
  private _setValue() {
    this.setFormValue(this.value);
    this._manageRequire();
  }

  private _manageRequire() {
    const input = this.shadowRoot?.querySelector("input");
    if (!input) return;
    const message = this.errorMessage || "This field is required.";
    const isInvalid = this.required && !this.value;
    if (isInvalid) {
      this.setValidityFromState({ valueMissing: true }, message, input);
    } else {
      this.clearValidity();
    }
  }

  private _handleInvalid = (event: Event) => {
    event.preventDefault();
    this._manageRequire();
    this.shadowRoot?.querySelector("input")?.focus();
  };
  {{else}}
  /**
   * Lifecycle methods
   * --------------------------------------------------------------------------
   * Automatic id generation is provided by NysElement (@nysds/internals).
   */
  connectedCallback() {
    super.connectedCallback(); // assigns an auto id when none is provided
  }
  {{/if}}

  /**
   * Functions
   * --------------------------------------------------------------------------
   */
  // Placeholder for component-specific functions

  /**
   * Event Handlers
   * --------------------------------------------------------------------------
   */
  // Placeholder for event handlers if needed

  render() {
    return html`<div class="nys-{{componentName}}"></div>`;
  }
}

if (!customElements.get("nys-{{componentName}}")) {
  customElements.define("nys-{{componentName}}", Nys{{capitalize componentName}});
}

{
  "name": "@nysds/components",
  "version": "1.18.3",
  "description": "New York State's design system and code component library.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "files": [
    "dist/",
    "custom-elements.json",
    "packages/react/"
  ],
  "main": "dist/nysds.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "require": "./dist/nysds.js"
    },
    "./nys-accordion": { "types": "./dist/packages/nys-accordion/src/index.d.ts", "import": "./dist/nys-accordion.js" },
    "./nys-alert": { "types": "./dist/packages/nys-alert/src/index.d.ts", "import": "./dist/nys-alert.js" },
    "./nys-avatar": { "types": "./dist/packages/nys-avatar/src/index.d.ts", "import": "./dist/nys-avatar.js" },
    "./nys-backtotop": { "types": "./dist/packages/nys-backtotop/src/index.d.ts", "import": "./dist/nys-backtotop.js" },
    "./nys-badge": { "types": "./dist/packages/nys-badge/src/index.d.ts", "import": "./dist/nys-badge.js" },
    "./nys-breadcrumbs": { "types": "./dist/packages/nys-breadcrumbs/src/index.d.ts", "import": "./dist/nys-breadcrumbs.js" },
    "./nys-button": { "types": "./dist/packages/nys-button/src/index.d.ts", "import": "./dist/nys-button.js" },
    "./nys-checkbox": { "types": "./dist/packages/nys-checkbox/src/index.d.ts", "import": "./dist/nys-checkbox.js" },
    "./nys-combobox": { "types": "./dist/packages/nys-combobox/src/index.d.ts", "import": "./dist/nys-combobox.js" },
    "./nys-datepicker": { "types": "./dist/packages/nys-datepicker/src/index.d.ts", "import": "./dist/nys-datepicker.js" },
    "./nys-divider": { "types": "./dist/packages/nys-divider/src/index.d.ts", "import": "./dist/nys-divider.js" },
    "./nys-dropdownmenu": { "types": "./dist/packages/nys-dropdownmenu/src/index.d.ts", "import": "./dist/nys-dropdownmenu.js" },
    "./nys-errormessage": { "types": "./dist/packages/nys-errormessage/src/index.d.ts", "import": "./dist/nys-errormessage.js" },
    "./nys-fileinput": { "types": "./dist/packages/nys-fileinput/src/index.d.ts", "import": "./dist/nys-fileinput.js" },
    "./nys-globalfooter": { "types": "./dist/packages/nys-globalfooter/src/index.d.ts", "import": "./dist/nys-globalfooter.js" },
    "./nys-globalheader": { "types": "./dist/packages/nys-globalheader/src/index.d.ts", "import": "./dist/nys-globalheader.js" },
    "./nys-icon": { "types": "./dist/packages/nys-icon/src/index.d.ts", "import": "./dist/nys-icon.js" },
    "./nys-label": { "types": "./dist/packages/nys-label/src/index.d.ts", "import": "./dist/nys-label.js" },
    "./nys-modal": { "types": "./dist/packages/nys-modal/src/index.d.ts", "import": "./dist/nys-modal.js" },
    "./nys-pagination": { "types": "./dist/packages/nys-pagination/src/index.d.ts", "import": "./dist/nys-pagination.js" },
    "./nys-radiobutton": { "types": "./dist/packages/nys-radiobutton/src/index.d.ts", "import": "./dist/nys-radiobutton.js" },
    "./nys-select": { "types": "./dist/packages/nys-select/src/index.d.ts", "import": "./dist/nys-select.js" },
    "./nys-skipnav": { "types": "./dist/packages/nys-skipnav/src/index.d.ts", "import": "./dist/nys-skipnav.js" },
    "./nys-stepper": { "types": "./dist/packages/nys-stepper/src/index.d.ts", "import": "./dist/nys-stepper.js" },
    "./nys-tab": { "types": "./dist/packages/nys-tab/src/index.d.ts", "import": "./dist/nys-tab.js" },
    "./nys-table": { "types": "./dist/packages/nys-table/src/index.d.ts", "import": "./dist/nys-table.js" },
    "./nys-textarea": { "types": "./dist/packages/nys-textarea/src/index.d.ts", "import": "./dist/nys-textarea.js" },
    "./nys-textinput": { "types": "./dist/packages/nys-textinput/src/index.d.ts", "import": "./dist/nys-textinput.js" },
    "./nys-toggle": { "types": "./dist/packages/nys-toggle/src/index.d.ts", "import": "./dist/nys-toggle.js" },
    "./nys-tooltip": { "types": "./dist/packages/nys-tooltip/src/index.d.ts", "import": "./dist/nys-tooltip.js" },
    "./nys-unavfooter": { "types": "./dist/packages/nys-unavfooter/src/index.d.ts", "import": "./dist/nys-unavfooter.js" },
    "./nys-unavheader": { "types": "./dist/packages/nys-unavheader/src/index.d.ts", "import": "./dist/nys-unavheader.js" },
    "./nys-video": { "types": "./dist/packages/nys-video/src/index.d.ts", "import": "./dist/nys-video.js" },
    "./react": {
      "import": "./packages/react/index.js",
      "types": "./packages/react/index.d.ts"
    }
  },
  "customElements": "custom-elements.json",
  "scripts": {
    "dev": "vite",
    "gen": "plop",
    "build": "tsc --emitDeclarationOnly && vite build",
    "build:umd": "cross-env BUILD_FORMAT=umd vite build",
    "tsc:packages": "tsc -b tsconfig.build.json",
    "build:packages": "npm run tsc:packages && turbo run build --filter='./packages/*' --log-order=grouped",
    "build:root": "cross-env NODE_ENV=production npm run build && cross-env NODE_ENV=production npm run build:umd",
    "build:all": "npm run clean:dist && npm run lint && npm run lit-analyze || true && cross-env NODE_ENV=production npm run build:packages && npm run build:root && npm run cem && npm run build:mcp",
    "build:mcp": "npm run build -w @nysds/mcp-server",
    "build:link": "npm run build:all && npm link && cd packages/styles && npm link",
    "lint": "eslint --cache --cache-strategy=content --cache-location node_modules/.cache/eslint && (stylelint \"**/*.scss\" || true)",
    "lint:fix": "bash src/scripts/lint-fix.sh",
    "lit-analyze": "find ./packages/nys-*/ -name '*.ts' ! -name '*.figma.*' | xargs lit-analyzer {}",
    "playwright:install": "npx playwright install --with-deps",
    "release": "cross-env NODE_ENV=production npm run build:all && cross-env NODE_ENV=production npm run test && npm run cem && cross-env NODE_ENV=production npm publish --workspaces --access public && cross-env NODE_ENV=production npm publish --access public",
    "release:dry-run": "cross-env NODE_ENV=production npm run build:all && cross-env NODE_ENV=production npm run test && npm run cem && node src/scripts/publish-dry-run.js",
    "release:alpha": "npm run build && npm run build:umd && npm publish --tag next",
    "release:zip": "npm run build:all && node src/scripts/create-release-zip.js",
    "test": "npm run playwright:install && wtr --node-resolve",
    "test:build": "npm run build:all && npm run test",
    "test:compact": "export NYSDS_TEST_OUTPUT=compact && wtr --node-resolve",
    "test:ai": "export NYSDS_TEST_OUTPUT=ai && wtr --node-resolve",
    "storybook": "cross-env NODE_ENV=production storybook dev -p 6006",
    "storybook:build:all": "cross-env NODE_ENV=production npm run build:all && npm run storybook",
    "build-storybook": "npm run build:packages && storybook build",
    "storybook:cibuild": "storybook build",
    "mcp-server:build": "turbo run build --filter=@nysds/mcp-server",
    "clean:node": "rm -rf node_modules && rm -rf packages/*/node_modules && rm -rf packages/**/*/node_modules",
    "clean:dist": "rm -rf storybook-static && rm -rf coverage && rm -rf packages/*/coverage && rm -rf dist && find packages -type d -name dist ! -path '*/mcp-server/dist' -exec rm -rf {} + 2>/dev/null || true",
    "clean:turbo": "find packages -type d -name '.turbo' -exec rm -rf {} + && rm -rf .turbo",
    "clean:cache": "rm -rf node_modules/.cache",
    "clean:all": "npm run clean:dist && npm run clean:node && npm run clean:cache && find packages -name '*.tsbuildinfo' -delete 2>/dev/null || true && npm run clean:turbo",
    "code-connect": "dotenv -- npx figma connect publish",
    "cem": "npx cem analyze --config ./custom-elements-manifest.config.mjs && cp ./custom-elements.json dist/ && node src/scripts/patch-react-utils.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ITS-HCD/nysds.git"
  },
  "author": "NYS Design System Team",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ITS-HCD/nysds/issues"
  },
  "homepage": "https://designsystem.ny.gov/",
  "packageManager": "npm@11.6.2",
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@figma/code-connect": "^1.4.0",
    "@floating-ui/dom": "^1.7.4",
    "@open-wc/testing": "^4.0.0",
    "@storybook/addon-a11y": "10.3.5",
    "@storybook/addon-docs": "10.3.5",
    "@storybook/addon-links": "10.3.5",
    "@storybook/web-components-vite": "10.3.5",
    "@types/mocha": "^10.0.10",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@wc-toolkit/wctools": "^0.0.9",
    "@web/dev-server-esbuild": "^1.0.4",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-commands": "^0.9.0",
    "@web/test-runner-playwright": "^0.11.1",
    "cem-plugin-examples": "github:its-hcd/cem-plugin-examples",
    "cross-env": "^10.1.0",
    "custom-element-jsx-integration": "^1.6.0",
    "custom-element-react-wrappers": "^1.7.3",
    "custom-element-vs-code-integration": "^1.5.0",
    "dotenv-cli": "^10.0.0",
    "eslint": "^10.0.0",
    "eslint-plugin-lit": "^2.2.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-storybook": "10.3.5",
    "i": "^0.3.7",
    "lit": "^3.3.1",
    "lit-analyzer": "^2.0.3",
    "plop": "^4.0.4",
    "prettier": "^3.8.1",
    "rollup-plugin-esbuild-minify": "^1.3.0",
    "rollup-plugin-minify-template-literals": "^1.1.7",
    "rollup-plugin-visualizer": "^6.0.5",
    "sass": "^1.94.0",
    "sinon": "^21.0.0",
    "storybook": "10.3.5",
    "stylelint": "^17.1.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-prettier": "^5.0.3",
    "tslib": "^2.8.1",
    "turbo": "^2.9.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  },
  "overrides": {
    "storybook": "$storybook"
  },
  "dependencies": {
    "dompurify": "^3.4.7",
    "wc-datepicker": "^0.10.0"
  }
}

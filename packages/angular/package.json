{
  "name": "@nysds/angular",
  "version": "0.1.0",
  "private": true,
  "description": "Angular directives for the New York State Design System web components. (NOTE: this is the source package — the publishable artifact is built into ./dist by ng-packagr. `private: true` keeps `npm publish --workspaces` from publishing the source folder; the root `release` script publishes ./dist explicitly.)",
  "license": "MIT",
  "author": "NYS Design System Team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ITS-HCD/nysds.git",
    "directory": "packages/angular"
  },
  "bugs": {
    "url": "https://github.com/ITS-HCD/nysds/issues"
  },
  "homepage": "https://designsystem.ny.gov/",
  "keywords": [
    "nysds",
    "angular",
    "web-components",
    "directives",
    "control-value-accessor",
    "new-york-state",
    "design-system"
  ],
  "sideEffects": [
    "./src/lib/form/*.directive.ts",
    "./src/lib/ui/*.directive.ts",
    "./fesm2022/*.mjs"
  ],
  "scripts": {
    "build": "ng-packagr -p ng-package.json && node scripts/strip-private.mjs",
    "dev": "ng-packagr -p ng-package.json --watch",
    "generate": "node scripts/generate-directives.mjs"
  },
  "peerDependencies": {
    "@angular/common": ">=20.0.0",
    "@angular/core": ">=20.0.0",
    "@angular/forms": ">=20.0.0",
    "@nysds/components": "^1.18.1"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  }
}

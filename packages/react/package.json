{
  "name": "@nysds/react",
  "version": "1.15.0",
  "description": "Auto-generated React wrappers for every NYSDS web component — no manual wrapper code required.",
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "import": "./index.js",
      "types": "./index.d.ts"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "*.js",
    "*.d.ts"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17",
    "@nysds/components": "^1.15.0"
  },
  "dependencies": {
    "@lit/react": "^1.0.0"
  },
  "keywords": [
    "nysds",
    "new-york-state",
    "design-system",
    "react"
  ],
  "author": "New York State Design System Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ITS-HCD/nysds.git",
    "directory": "packages/react"
  }
}
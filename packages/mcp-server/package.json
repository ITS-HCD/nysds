{
  "name": "@nysds/mcp-server",
  "version": "1.16.2-alpha1",
  "description": "MCP server for the New York State Design System. Exposes components, tokens, and documentation to AI assistants.",
  "type": "module",
  "bin": {
    "nysds-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "data/"
  ],
  "scripts": {
    "copy-data": "mkdir -p data/cem data/tokens && cp ../../custom-elements.json data/cem/ && cp ../tokens/src/tokens.json data/tokens/ && cp ../tokens/dist/tokens.css data/tokens/",
    "build": "npm run copy-data && tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "inspect": "npx -y @modelcontextprotocol/inspector node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^3.25"
  },
  "devDependencies": {
    "@nysds/components": "^1.16.1",
    "@nysds/styles": "^1.16.1",
    "@nysds/tokens": "^1.16.1",
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "new-york-state",
    "design-system",
    "web-components",
    "ai-assistant"
  ],
  "author": "New York State Design System Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ITS-HCD/nysds.git",
    "directory": "packages/mcp-server"
  }
}

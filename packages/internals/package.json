{
  "name": "@nysds/internals",
  "version": "1.19.0",
  "private": true,
  "description": "Shared base classes and mixins (ElementInternals + ARIA wiring) for NYSDS components. Internal — not a custom element and not published.",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist/"
  ],
  "scripts": {
    "dev": "tsc --emitDeclarationOnly && vite",
    "build": "vite build",
    "build:watch": "tsc --emitDeclarationOnly && vite build --watch",
    "test": "vite build && wtr",
    "test:watch": "vite build && wtr --watch",
    "lit-analyze": "lit-analyzer '**/*.ts'"
  },
  "devDependencies": {
    "lit": "^3.3.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "keywords": [
    "new-york-state",
    "design-system",
    "web-components",
    "lit",
    "nys",
    "internals",
    "accessibility"
  ],
  "author": "New York State Design System Team",
  "license": "MIT"
}
